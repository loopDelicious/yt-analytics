SITE_PASSWORD=your-password-here
SECRET_KEY=generate-a-random-string-here

# --- Data source (choose one) ---

# Option 1: YouTube API (recommended)
# Run setup_youtube.py first to generate .youtube_token.json
# For Render, paste the token JSON as this env var:
# YOUTUBE_TOKEN_JSON={"token":"...","refresh_token":"...","client_id":"...","client_secret":"..."}
# Optional: set a specific channel ID (auto-detected if omitted)
# YOUTUBE_CHANNEL_ID=UCxxxxxxxx

# Option 2: Remote xlsx file (e.g. Google Sheets export URL)
# DATA_URL=https://docs.google.com/spreadsheets/d/SHEET_ID/export?format=xlsx

# Option 3: Local xlsx file — just place a "Lifetime snapshot *.xlsx" in the project root

# Cache TTL in seconds (default 600 = 10 minutes)
# CACHE_TTL=600
